# GitHub Personal Access Token（サーバー専用。NEXT_PUBLIC_ を付けないこと）
# スコープ: 公開リポジトリのみなら public_repo / private も見るなら repo
# 将来 組織・チームを扱う際は read:org を追加
GITHUB_TOKEN=

# 任意。未指定なら GET /user で自動解決
GITHUB_USERNAME=

# 将来の組織切替用（現状は未使用）
# GITHUB_ORG=

# ローカルAI（llama.cpp 等の OpenAI 互換サーバ）。サーバー専用・NEXT_PUBLIC_ を付けないこと
# 既定値で動くので、別ポート/別モデルのときのみ設定
LOCAL_AI_BASE_URL=http://localhost:8080/v1
LOCAL_AI_MODEL=gemma-4-e4b-it-Q4_K_M.gguf
# 認証付きサーバを使う場合のみ（llama.cpp では通常不要）
# LOCAL_AI_API_KEY=
